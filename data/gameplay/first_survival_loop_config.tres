nutrition_drain = 8
fatigue_delta = 11
morale_delta = 0
hygiene_delta = -7
available_from_minutes = 480
available_until_minutes = 1080
can_persist = true
persistence_chance_percent = 55
persistent_days_min = 2
persistent_days_max = 3

[resource]
script = ExtResource("1_config")
day_limit = 28
support_goal_cents = 1500
send_small_amount_cents = 375
send_large_amount_cents = 750
monthly_support_target_cents = 1500
support_obligation_defaults = Array[Dictionary]([{
"checkpoint_day": 7,
"label": "Week 1",
"obligation_id": &"week_1",
"target_cents": 375
}, {
"checkpoint_day": 14,
"label": "Week 2",
"obligation_id": &"week_2",
"target_cents": 375
}, {
"checkpoint_day": 21,
"label": "Week 3",
"obligation_id": &"week_3",
"target_cents": 375
}, {
"checkpoint_day": 28,
"label": "Week 4",
"obligation_id": &"week_4",
"target_cents": 375
}])
support_send_methods = Array[Dictionary]([{
"delivery_delay_days": 2,
"display_name": "Mail",
"fee_cents": 5,
"method_id": &"mail"
}, {
"delivery_delay_days": 0,
"display_name": "Telegraph",
"fee_cents": 25,
"method_id": &"telegraph"
}])
job_templates = Array[ExtResource("2_job_template")]([SubResource("JobTemplate_hiring_line"), SubResource("JobTemplate_hammer_repair"), SubResource("JobTemplate_kitchen_cleanup"), SubResource("JobTemplate_yard_scrounge"), SubResource("JobTemplate_coal_shovel"), SubResource("JobTemplate_salvage_sort")])
