duration_minutes = 240
pay_cents = 126
nutrition_drain = 18
fatigue_delta = 24
morale_delta = -4
hygiene_delta = -18
available_from_minutes = 360
available_until_minutes = 840

[sub_resource type="Resource" id="JobTemplate_salvage_sort"]
script = ExtResource("2_job_template")
template_id = &"salvage_sort"
