can_persist = true
persistence_chance_percent = 40
persistent_days_min = 2
persistent_days_max = 2

[sub_resource type="Resource" id="JobTemplate_yard_scrounge"]
script = ExtResource("2_job_template")
template_id = &"yard_scrounge_pull"
title = "Yard Edge Scrounge"
summary = "No one is paying wages, but there is still salvage to be had if you are willing to stoop for it."
job_category = &"desperation_salvage"
decay_behavior = &"expire"
max_appearance_tier = &"disheveled"
appearance_requirement_text = "Available when you look rough enough that no one mistakes this for steady hiring."
weight = 11
duration_minutes = 150
pay_cents = 0
nutrition_drain = 7
fatigue_delta = 9
morale_delta = -5
hygiene_delta = -10
available_from_minutes = 360
available_until_minutes = 1080
reward_item_id = &"scrap_tin"
reward_item_quantity = 2
fading_income_source = &"scrounge"

[sub_resource type="Resource" id="JobTemplate_coal_shovel"]
script = ExtResource("2_job_template")
template_id = &"coal_shovel_run"
title = "Coal Shovel Run"
summary = "Hard, filthy pay for a short burst of brutal work near the rail spur."
job_category = &"industrial"
decay_behavior = &"expire"
min_appearance_tier = &"filthy_unkept"
appearance_requirement_text = "Dirt does not disqualify you here; the work will cover everyone in coal dust anyway."
