[gd_resource type="Resource" script_class="SurvivalLoopConfig" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/gameplay/survival_loop_config.gd" id="1_config"]
[ext_resource type="Script" path="res://scripts/gameplay/survival_job_template.gd" id="2_job_template"]

[sub_resource type="Resource" id="JobTemplate_hiring_line"]
script = ExtResource("2_job_template")
template_id = &"hiring_line_labor"
title = "Hiring Line Day Labor"
summary = "A foreman needs hands for loading and rough haul work before noon."
job_category = &"day_labor"
decay_behavior = &"degrade_pay"
pay_decay_cents_per_day = 12
minimum_pay_cents = 82
min_appearance_tier = &"disheveled"
appearance_requirement_text = "At least disheveled; the foreman wants a man who can still stand in a hiring line."
weight = 14
duration_minutes = 300
pay_cents = 112
nutrition_drain = 15
fatigue_delta = 18
morale_delta = -3
hygiene_delta = -8
available_from_minutes = 360
available_until_minutes = 780

[sub_resource type="Resource" id="JobTemplate_hammer_repair"]
script = ExtResource("2_job_template")
template_id = &"hammer_repair_call"
title = "Hammer Repair Odd Job"
summary = "A rough repair call that only opens if you still have a usable hammer on you."
job_category = &"town_odd_jobs"
decay_behavior = &"stable"
min_appearance_tier = &"presentable"
appearance_requirement_text = "Presentable enough for private repair work."
weight = 9
duration_minutes = 210
pay_cents = 84
nutrition_drain = 8
fatigue_delta = 12
morale_delta = 2
hygiene_delta = -4
available_from_minutes = 420
available_until_minutes = 1020
required_item_id = &"claw_hammer"
can_persist = true
persistence_chance_percent = 70
persistent_days_min = 2
persistent_days_max = 3

[sub_resource type="Resource" id="JobTemplate_kitchen_cleanup"]
